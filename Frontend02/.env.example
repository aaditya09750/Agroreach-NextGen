# Local dev — point at the running Node backend and Python ML service
VITE_API_BASE_URL=http://localhost:5000/api
VITE_ML_API_URL=http://localhost:5001

# Weather widget — uses Open-Meteo (https://open-meteo.com), which is FREE
# and KEY-LESS. No env var required. The variable below is unused but kept
# as a placeholder in case you swap to a paid provider later (e.g., OpenWeather).
# VITE_WEATHER_API_KEY=
