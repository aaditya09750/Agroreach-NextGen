# ─────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────
# Database (MongoDB Atlas in production)
# ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/ar-ecommerce

# ─────────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-64-byte-random-string
JWT_EXPIRE=7d

# ─────────────────────────────────────────────────────────────────
# CORS — comma-separated list of frontend origins
# In production set to: https://<shop>.vercel.app,https://<farmer>.vercel.app
# In dev a single value also works (FRONTEND_URL is read as a fallback).
# ─────────────────────────────────────────────────────────────────
FRONTEND_URLS=http://localhost:5174,http://localhost:5175
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────
# Email (Gmail App Password — NOT your real password)
# Get one: Google Account → Security → 2-Step Verification → App passwords
# ─────────────────────────────────────────────────────────────────
EMAIL_SERVICE=gmail
EMAIL_USER=agroreach01@gmail.com
EMAIL_PASS=your-16-char-app-password
ADMIN_EMAIL=agroreach01@gmail.com

# ─────────────────────────────────────────────────────────────────
# Cloudinary (image storage — required in production)
# Sign up free at cloudinary.com; copy from Dashboard → Settings → API Keys
# ─────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
